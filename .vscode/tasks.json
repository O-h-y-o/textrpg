{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure (Ninja)",
      "type": "shell",
      "command": "${workspaceFolder}\\.vscode\\configure-ninja.bat",
      "options": {
        "shell": {
          "executable": "C:\\Windows\\System32\\cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "CMake: Build (Ninja)",
      "type": "shell",
      "command": "${workspaceFolder}\\.vscode\\build-ninja.bat",
      "options": {
        "shell": {
          "executable": "C:\\Windows\\System32\\cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Run (Ninja)",
      "type": "shell",
      "command": "${workspaceFolder}\\build-ninja\\outDebug.exe",
      "options": {
        "shell": {
          "executable": "C:\\Windows\\System32\\cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "problemMatcher": []
    }
  ]
}
